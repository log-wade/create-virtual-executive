# Required for generation and chat
ANTHROPIC_API_KEY=

# Optional; default shown below
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional IP rate limiting (enable in production / multi-tenant)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# When set, also enables Twilio CallSid conversation memory (see PHONE_CALL_* below).

# Optional web voice — server-side only (never NEXT_PUBLIC_* for these)
# ElevenLabs TTS: https://elevenlabs.io/ — voice ID from API or dashboard
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# Optional model override (e.g. eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=

# Deepgram STT — enables chat **Mic** → POST /api/stt
# DEEPGRAM_API_KEY=

# Optional: override bundled demo glTF (path under public/ or absolute URL)
# NEXT_PUBLIC_AVATAR_MODEL_URL=/avatars/your-executive.glb

# Twilio inbound voice (Gather → Claude complete → Say)
# PUBLIC_BASE_URL=https://your-deployment.example.com
# TWILIO_AUTH_TOKEN=<primary auth token; enables X-Twilio-Signature verification>
# TWILIO_ACCOUNT_SID=<AC...> (required for outbound API)
# TWILIO_VOICE_FROM_NUMBER=+15551234567 (caller ID; E.164, required for outbound)
# TWILIO_VOICE_PERSONA_ID=<persona id from data/personas>
# TWILIO_OUTBOUND_API_SECRET=<random secret for POST /api/admin/twilio/outbound>
# TWILIO_VOICE_BARGE_IN=true (default true; nest Say in Gather for speech interrupt)
# Optional: Redis session tuning for phone multi-turn (requires Upstash vars above)
# PHONE_CALL_SESSION_TTL_SECONDS=86400
# PHONE_CALL_MAX_MESSAGES=40
